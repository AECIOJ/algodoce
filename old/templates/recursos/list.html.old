{% extends "components/page_system.html" %}
{% block content %}

{% from "components/panel_list.html" import panel_list, card_list, action_edit %}

{% set _actions %}
<a href="{{ url_for('recursos.create') }}" class="btn btn-success">+ Novo</a>
{% endset %}

{% set filter_html %}
<select class="form-select" style="width:auto;" onchange="filtrar('tipo', this.value)">
  <option value="todos" {% if filtro_tipo == 'todos' %}selected{% endif %}>Todos</option>
  {% for k, v in TIPO_RECURSO.items() %}
    <option value="{{ k }}" {% if filtro_tipo == k|string %}selected{% endif %}>{{ v }}</option>
  {% endfor %}
</select>
{% endset %}

{% call panel_list("Recursos", actions=_actions, filters=filter_html, table_wrapper_class='d-none d-lg-block', model="Recurso") %}
  <thead>
    <tr>
      <th>#</th>
      <th data-field="nome">Nome</th>
      <th>Tipo</th>
      <th class="text-end">Saldo</th>
      <th>Balanço</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    {% for r in recursos %}
      <tr>
        <td>{{ r.id|fmtid }}</td>
        <td>{{ r.nome }}</td>
        <td>{{ TIPO_RECURSO.get(r.tipo, r.tipo) }}</td>
        <td class="text-end">{{ r.saldo|brl }}</td>
        <td>{{ r.data|fmtdate if r.data else '' }}</td>
        <td>{{ action_edit(url_for('recursos.edit', id=r.id)) }}</td>
      </tr>
    {% else %}
      <tr>
        <td colspan="6" class="text-center text-muted">Nenhum registro encontrado.</td>
      </tr>
    {% endfor %}
  </tbody>
{% endcall %}

{% call(item) card_list(recursos) %}
  <div class="d-flex justify-content-between align-items-start mb-1">
    <span class="fw-bold">{{ item.nome }}</span>
    {{ action_edit(url_for('recursos.edit', id=item.id)) }}
  </div>
  <span class="card-label">#{{ item.id|fmtid }}</span>
  <span class="badge bg-info ms-1">{{ TIPO_RECURSO.get(item.tipo, item.tipo) }}</span>
  <span class="card-label ms-2">Saldo:</span>
  <span class="card-value ms-1">{{ item.saldo|brl }}</span>
  {% if item.data %}
    <br><span class="card-label">Balanço:</span>
    <span class="card-value ms-1">{{ item.data|fmtdate }}</span>
  {% endif %}
{% endcall %}

{% endblock %}

{% block scripts %}
<script>
function filtrar(chave, valor) {
  var params = new URLSearchParams(window.location.search);
  params.set(chave, valor);
  window.location = '?' + params.toString();
}
</script>
{% endblock %}
