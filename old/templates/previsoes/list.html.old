{% extends "components/page_system.html" %}
{% from "components/panel_list.html" import panel_list, card_list, action_edit %}
{% block content %}

{% set _actions %}
<a href="{{ url_for('previsoes.new') }}" class="btn btn-success">+ Nova</a>
{% endset %}

{% set filter_html %}
<select class="form-select" style="width:auto;" onchange="filtrar('tipo', this.value)">
  <option value="todos" {% if filtro_tipo == 'todos' %}selected{% endif %}>Todas</option>
  <option value="R" {% if filtro_tipo == 'R' %}selected{% endif %}>A Receber</option>
  <option value="P" {% if filtro_tipo == 'P' %}selected{% endif %}>A Pagar</option>
</select>
<select class="form-select" style="width:auto;" onchange="filtrar('status', this.value)">
  <option value="todos" {% if filtro_status == 'todos' %}selected{% endif %}>Todos</option>
  {% for k, v in PREVISAO_STATUS.items() %}
    <option value="{{ k }}" {% if filtro_status == k|string %}selected{% endif %}>{{ v }}</option>
  {% endfor %}
</select>
<select class="form-select" style="width:auto;" onchange="filtrar('vencimento', this.value)">
  <option value="todos" {% if filtro_venc == 'todos' %}selected{% endif %}>Todas</option>
  <option value="em_atraso" {% if filtro_venc == 'em_atraso' %}selected{% endif %}>Em atraso</option>
  <option value="hoje" {% if filtro_venc == 'hoje' %}selected{% endif %}>Hoje</option>
  <option value="a_vencer" {% if filtro_venc == 'a_vencer' %}selected{% endif %}>A Vencer</option>
</select>
{% endset %}

{% call panel_list("Previsões", actions=_actions, filters=filter_html, model="Previsao") %}
  <thead>
    <tr>
      <th>#</th>
      <th>Data</th>
      <th>Tipo</th>
      <th>Status</th>
      <th>Conta</th>
      <th data-field="documento">Documento</th>
      <th>Vencimento</th>
      <th>Previsto</th>
      <th>Variação</th>
      <th>Realizado</th>
      <th>Saldo</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    {% for p in previsoes %}
      <tr class="{{ 'table-danger' if p.vencimento < hoje and p.status != 9 and p.status != 8 else '' }}">
        <td>{{ p.id|fmtid }}</td>
        <td>{{ p.data|fmtdate }}</td>
        <td><span class="badge bg-{{ 'success' if p.tipo == 'R' else 'danger' }}">{{ TIPO_PREVISAO.get(p.tipo, p.tipo) }}</span></td>
        <td>
          {% set st = PREVISAO_STATUS.get(p.status, '') %}
          {% if p.status == 9 %}
            <span class="badge bg-success">{{ st }}</span>
          {% elif p.status == 8 %}
            <span class="badge bg-secondary">{{ st }}</span>
          {% elif p.status == 1 %}
            <span class="badge bg-warning">{{ st }}</span>
          {% else %}
            <span class="badge bg-info">{{ st }}</span>
          {% endif %}
        </td>
        <td>{{ p.conta.nome if p.conta else '' }}</td>
        <td>{{ p.documento }}</td>
        <td>{{ p.vencimento|fmtdate }}</td>
        {% set saldo = p.previsto + (p.variacao or 0) - (p.realizado or 0) %}
        <td class="text-end">{{ p.previsto|brl }}</td>
        <td class="text-end">{{ p.variacao|brl if p.variacao else '-' }}</td>
        <td class="text-end">{{ p.realizado|brl if p.realizado is not none else '-' }}</td>
        <td class="text-end {{ 'text-danger' if saldo > 0 else ('text-success' if saldo <= 0 else '') }}">{{ saldo|brl }}</td>
        <td>{{ action_edit(url_for('previsoes.edit', id=p.id)) }}</td>
      </tr>
    {% else %}
      <tr>
        <td colspan="11" class="text-center text-muted">Nenhum registro encontrado.</td>
      </tr>
    {% endfor %}
  </tbody>
{% endcall %}

{% call(item) card_list(previsoes) %}
  <div class="d-flex justify-content-between align-items-start mb-1">
    <div>
      <span class="card-label">#{{ item.id|fmtid }}</span>
      <span class="badge bg-{{ 'success' if item.tipo == 'R' else 'danger' }}">{{ TIPO_PREVISAO.get(item.tipo, item.tipo) }}</span>
    </div>
    {{ action_edit(url_for('previsoes.edit', id=item.id)) }}
  </div>
  <h6 class="mb-1">{{ item.previsto|brl }}</h6>
  {% if item.variacao %}
    <span class="card-label">Variação:</span>
    <span class="card-value ms-1">{{ item.variacao|brl }}</span>
  {% endif %}
  {% if item.realizado is not none %}
    <span class="card-label">Realizado:</span>
    <span class="card-value ms-1">{{ item.realizado|brl }}</span>
  {% endif %}
  {% set saldo = item.previsto + (item.variacao or 0) - (item.realizado or 0) %}
  <span class="card-label">Saldo:</span>
  <span class="card-value ms-1 {{ 'text-danger' if saldo > 0 else ('text-success' if saldo <= 0 else '') }}">{{ saldo|brl }}</span>
  <span class="card-label">Conta:</span>
  <span class="card-value ms-1">{{ item.conta.nome if item.conta else '' }}</span>
  {% if item.vencimento %}
    <span class="card-label ms-2">Venc:</span>
    <span class="card-value ms-1">{{ item.vencimento|fmtdate }}</span>
  {% endif %}
{% endcall %}

{% endblock %}

{% block scripts %}
<script>
function filtrar(chave, valor) {
  var params = new URLSearchParams(window.location.search);
  params.set(chave, valor);
  window.location = '?' + params.toString();
}
</script>
{% endblock %}
